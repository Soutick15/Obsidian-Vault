		{
			"id":"74ab53a889ed2ef3",
			"type":"text",
			"text":"```dataviewjs\n// Configuration\nconst habitProperty = \"reading\"; // The checkbox property to track\n\n// Create a unique ID for this calendar instance\nconst containerId = `habit-calendar-${habitProperty}`;\n\n// Function to calculate streak statistics\nfunction calculateStreaks(habitData, year, month) {\n    // Get all dates for the habit, sorted\n    const allDates = Array.from(habitData.entries())\n        .filter(([date, completed]) => completed === true)\n        .map(([date]) => date)\n        .sort();\n    \n    const totalDays = habitData.size; // Total days with data\n    const completedDays = allDates.length;\n    const completionPercentage = totalDays > 0 ? Math.round((completedDays / totalDays) * 100) : 0;\n    \n    if (allDates.length === 0) {\n        return {\n            currentStreak: 0,\n            longestStreak: 0,\n            longestBreak: 0,\n            totalCompleted: 0,\n            completionPercentage: completionPercentage\n        };\n    }\n    \n    // Calculate streaks and breaks\n    let currentStreak = 0;\n    let longestStreak = 0;\n    let longestBreak = 0;\n    let tempStreak = 1;\n    let tempBreak = 0;\n    \n    const today = dv.date(\"today\").toFormat('yyyy-MM-dd');\n    \n    // Check if there's a current streak\n    const yesterday = dv.date(\"today\").minus({days: 1}).toFormat('yyyy-MM-dd');\n    if (allDates.includes(today) || allDates.includes(yesterday)) {\n        // Start from most recent and work backwards\n        let checkDate = allDates.includes(today) ? dv.date(\"today\") : dv.date(\"today\").minus({days: 1});\n        currentStreak = 0;\n        \n        while (true) {\n            const dateKey = checkDate.toFormat('yyyy-MM-dd');\n            if (habitData.get(dateKey) === true) {\n                currentStreak++;\n                checkDate = checkDate.minus({days: 1});\n            } else {\n                break;\n            }\n        }\n    }\n    \n    // Calculate longest streak and longest break\n    for (let i = 1; i < allDates.length; i++) {\n        const prevDate = dv.date(allDates[i - 1]);\n        const currDate = dv.date(allDates[i]);\n        const daysDiff = currDate.diff(prevDate, 'days').days;\n        \n        if (daysDiff === 1) {\n            // Consecutive days - continue streak\n            tempStreak++;\n            if (tempBreak > 0) {\n                longestBreak = Math.max(longestBreak, tempBreak);\n                tempBreak = 0;\n            }\n        } else {\n            // Break in streak\n            longestStreak = Math.max(longestStreak, tempStreak);\n            tempStreak = 1;\n            tempBreak = daysDiff - 1; // Number of days missed\n            longestBreak = Math.max(longestBreak, tempBreak);\n        }\n    }\n    longestStreak = Math.max(longestStreak, tempStreak);\n    \n    return {\n        currentStreak: currentStreak,\n        longestStreak: longestStreak,\n        longestBreak: longestBreak,\n        totalCompleted: completedDays,\n        completionPercentage: completionPercentage\n    };\n}\n\n// Function to render the calendar\nfunction renderCalendar(monthOffset) {\n    const currentDate = dv.date(\"today\").plus({months: monthOffset});\n    const year = currentDate.year;\n    const month = currentDate.month;\n\n    // Get all daily notes with the reading property\n    const pages = dv.pages('\"Daily Notes\"') // Adjust path to your daily notes folder\n        .where(p => p.file.day && p[habitProperty] !== undefined)\n        .sort(p => p.file.day, 'asc');\n\n    // Create a map of dates to habit completion status\n    const habitData = new Map();\n    pages.forEach(p => {\n        const dateKey = p.file.day.toFormat('yyyy-MM-dd');\n        habitData.set(dateKey, p[habitProperty] === true);\n    });\n\n    // Calculate streaks\n    const stats = calculateStreaks(habitData, year, month);\n\n    // Get first and last day of current month\n    const firstDay = dv.date(`${year}-${String(month).padStart(2, '0')}-01`);\n    const lastDay = firstDay.plus({months: 1}).minus({days: 1});\n    const daysInMonth = lastDay.day;\n\n    // Get starting day of week (1 = Monday, 7 = Sunday)\n    // Convert to 0-based where 0 = Monday, 6 = Sunday\n    const luxonWeekday = firstDay.weekday; // 1=Mon, 7=Sun\n    const startDayOfWeek = luxonWeekday === 7 ? 6 : luxonWeekday - 1; // Convert to 0=Mon, 6=Sun\n\n    // Month name\n    const monthName = firstDay.toFormat('MMMM yyyy');\n    const todayKey = dv.date(\"today\").toFormat('yyyy-MM-dd');\n\n    // Build array of all cells (including empty ones)\n    const cells = [];\n    \n    // Add previous month dates\n    if (startDayOfWeek > 0) {\n        const prevMonthLastDay = firstDay.minus({days: 1});\n        const prevMonthDaysInMonth = prevMonthLastDay.day;\n        \n        for (let i = startDayOfWeek - 1; i >= 0; i--) {\n            const day = prevMonthDaysInMonth - i;\n            const prevMonthDate = firstDay.minus({days: i + 1});\n            const dateKey = prevMonthDate.toFormat('yyyy-MM-dd');\n            \n            cells.push({\n                isEmpty: false,\n                isPrevMonth: true,\n                day: day,\n                dateKey: dateKey,\n                isCompleted: habitData.get(dateKey) === true,\n                hasData: habitData.has(dateKey),\n                isToday: dateKey === todayKey\n            });\n        }\n    }\n    \n    // Add all days of the current month\n    for (let day = 1; day <= daysInMonth; day++) {\n        const dateKey = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;\n        cells.push({\n            isEmpty: false,\n            isPrevMonth: false,\n            day: day,\n            dateKey: dateKey,\n            isCompleted: habitData.get(dateKey) === true,\n            hasData: habitData.has(dateKey),\n            isToday: dateKey === todayKey\n        });\n    }\n\n    // Build calendar HTML\n    let html = `\n    <h1 style=\"margin: 10px 0 20px 0; text-align: center;\">📖 Reading Streak</h1>\n    <div style=\"display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px;\">\n        <button class=\"prev-month\" style=\"padding: 6px 12px; cursor: pointer; background: var(--interactive-normal); border: 1px solid var(--background-modifier-border); border-radius: 4px; color: var(--text-normal);\">← Prev</button>\n        <h3 style=\"margin: 0;\">${monthName}</h3>\n        <button class=\"next-month\" style=\"padding: 6px 12px; cursor: pointer; background: var(--interactive-normal); border: 1px solid var(--background-modifier-border); border-radius: 4px; color: var(--text-normal);\">Next →</button>\n    </div>\n    <div style=\"display: grid; grid-template-columns: repeat(7, 1fr); gap: 12px; margin-bottom: 15px;\">\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Mon</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Tue</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Wed</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Thu</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Fri</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Sat</div>\n        <div style=\"text-align: center; font-weight: 600; color: var(--text-muted); font-size: 0.85em; padding: 8px 0;\">Sun</div>\n    `;\n\n    // Render each cell\n    cells.forEach((cell, index) => {\n        if (cell.isEmpty) {\n            html += '<div style=\"height: 50px;\"></div>';\n            return;\n        }\n        \n        const posInRow = index % 7;\n        const isLastInRow = posInRow === 6;\n        const isFirstInRow = posInRow === 0;\n        \n        // Check for connections\n        const prevCell = index > 0 ? cells[index - 1] : null;\n        const nextCell = index < cells.length - 1 ? cells[index + 1] : null;\n        \n        // Regular horizontal connections within same row\n        const hasLineFromPrev = prevCell && !prevCell.isEmpty && prevCell.isCompleted && cell.isCompleted && !isFirstInRow;\n        const hasLineToNext = nextCell && !nextCell.isEmpty && nextCell.isCompleted && cell.isCompleted && !isLastInRow;\n        \n        // Week-wrapping connections\n        const hasWrapLineFromPrev = prevCell && !prevCell.isEmpty && prevCell.isCompleted && cell.isCompleted && isFirstInRow;\n        const hasWrapLineToNext = nextCell && !nextCell.isEmpty && nextCell.isCompleted && cell.isCompleted && isLastInRow;\n        \n        // Use darker colors for previous month\n        const dotColor = cell.isPrevMonth ? '#1a5c28' : '#2CC742';  // Darker green for prev month\n        const lineColor = cell.isPrevMonth ? '#1a5c28' : '#2CC742'; // Darker green for prev month\n        const completedTextColor = cell.isPrevMonth ? '#888' : 'white';\n        const missedTextColor = cell.isPrevMonth ? '#888' : 'var(--text-normal)';\n        \n        let dotStyle = `\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            margin: 0 auto;\n            position: relative;\n            z-index: 2;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: 500;\n            font-size: 1em;\n            cursor: pointer;\n        `;\n        \n        if (cell.hasData) {\n            if (cell.isCompleted) {\n                // Filled dot for completed\n                dotStyle += `background-color: ${dotColor}; color: ${completedTextColor};`;\n            } else {\n                // Empty dot (ring) for missed\n                dotStyle += `background-color: transparent; border: 3px solid ${cell.isPrevMonth ? '#7d3a37' : '#FE5F58'}; color: ${missedTextColor};`;\n            }\n        } else {\n            // No dot for days without data - just show the number\n            dotStyle += `background-color: transparent; color: ${cell.isPrevMonth ? '#666' : 'var(--text-muted)'};`;\n        }\n        \n        if (cell.isToday && cell.hasData) {\n            dotStyle += 'box-shadow: 0 0 0 3px var(--interactive-accent);';\n        }\n        \n        // Build the line elements\n        let lineHTML = '';\n        \n        // Determine line color based on whether we're connecting prev month cells\n        const leftLineColor = (hasLineFromPrev && prevCell.isPrevMonth && cell.isPrevMonth) ? '#1a5c28' : lineColor;\n        const rightLineColor = (hasLineToNext && cell.isPrevMonth && nextCell.isPrevMonth) ? '#1a5c28' : lineColor;\n        \n        // Regular horizontal line from previous day (same row)\n        if (hasLineFromPrev) {\n            lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${leftLineColor}; top: 50%; left: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        }\n        \n        // Regular horizontal line to next day (same row)\n        if (hasLineToNext) {\n            lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${rightLineColor}; top: 50%; right: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        }\n        \n        // Wrap line from end of previous week (extends from left edge)\n        if (hasWrapLineFromPrev) {\n            const wrapLeftLineColor = (prevCell.isPrevMonth && cell.isPrevMonth) ? '#1a5c28' : lineColor;\n            lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${wrapLeftLineColor}; top: 50%; left: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        }\n        \n        // Wrap line to start of next week (extends to right edge)\n        if (hasWrapLineToNext) {\n            const wrapRightLineColor = (cell.isPrevMonth && nextCell.isPrevMonth) ? '#1a5c28' : lineColor;\n            lineHTML += `<div style=\"position: absolute; width: calc(50% + 12px); height: 3px; background-color: ${wrapRightLineColor}; top: 50%; right: -12px; transform: translateY(-50%); z-index: 1;\"></div>`;\n        }\n        \n        html += `\n        <div style=\"text-align: center; position: relative; height: 50px;\">\n            ${lineHTML}\n            <div class=\"date-link\" data-date=\"${cell.dateKey}\" style=\"${dotStyle}\">${cell.day}</div>\n        </div>\n        `;\n    });\n\n    html += `\n    </div>\n    <div style=\"margin-top: 20px; display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; padding: 15px; background: var(--background-secondary); border-radius: 8px;\">\n        <div style=\"text-align: center;\">\n            <div style=\"font-size: 1.5em; font-weight: 700; color: #2CC742;\">${stats.currentStreak}</div>\n            <div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Current Streak</div>\n        </div>\n        <div style=\"text-align: center;\">\n            <div style=\"font-size: 1.5em; font-weight: 700; color: #DAA520;\">${stats.longestStreak}</div>\n            <div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Longest Streak</div>\n        </div>\n        <div style=\"text-align: center;\">\n            <div style=\"font-size: 1.5em; font-weight: 700; color: #FE5F58;\">${stats.longestBreak}</div>\n            <div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Longest Break</div>\n        </div>\n        <div style=\"text-align: center;\">\n            <div style=\"font-size: 1.5em; font-weight: 700; color: var(--text-normal);\">${stats.completionPercentage}%</div>\n            <div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Completion Percentage</div>\n        </div>\n        <div style=\"text-align: center;\">\n            <div style=\"font-size: 1.5em; font-weight: 700; color: var(--text-normal);\">${stats.totalCompleted}</div>\n            <div style=\"font-size: 0.85em; color: var(--text-muted); margin-top: 4px;\">Total Days Completed</div>\n        </div>\n    </div>\n    `;\n\n    return html;\n}\n\n// Initial render\nlet currentOffset = 0;\nconst container = dv.container;\ncontainer.innerHTML = `\n<div id=\"${containerId}\" style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\">\n    ${renderCalendar(currentOffset)}\n</div>\n`;\n\n// Setup event listeners\nfunction setupListeners() {\n    const calendarDiv = container.querySelector(`#${containerId}`);\n    \n    const prevBtn = calendarDiv.querySelector('.prev-month');\n    const nextBtn = calendarDiv.querySelector('.next-month');\n    \n    prevBtn.addEventListener('click', () => {\n        currentOffset--;\n        calendarDiv.innerHTML = renderCalendar(currentOffset);\n        setupListeners();\n    });\n    \n    nextBtn.addEventListener('click', () => {\n        currentOffset++;\n        calendarDiv.innerHTML = renderCalendar(currentOffset);\n        setupListeners();\n    });\n    \n    // Add click handlers for date links\n    const dateLinks = calendarDiv.querySelectorAll('.date-link');\n    dateLinks.forEach(link => {\n        link.addEventListener('click', (e) => {\n            const dateKey = e.target.getAttribute('data-date');\n            // Open the daily note for this date\n            const dailyNotePath = `Daily Notes/${dateKey}.md`;\n            app.workspace.openLinkText(dailyNotePath, '', false);\n        });\n    });\n}\n\nsetupListeners();\n```",
